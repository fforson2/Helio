# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# OpenAI
OPENAI_API_KEY=your_openai_key_here

# Groq (fast inference for chat/voice)
GROQ_API_KEY=your_groq_key_here

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# LiveKit (for voice sessions)
LIVEKIT_URL=wss://your-livekit-cloud-url.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Google Maps (optional, for geocoding)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_key_here

# RentCast (live listings)
RENTCAST_API_KEY=your_rentcast_api_key_here
