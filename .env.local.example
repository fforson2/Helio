# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=

# OpenAI
OPENAI_API_KEY=

# Groq (fast inference for chat/voice)
GROQ_API_KEY=

# ElevenLabs (Text-to-Speech)
ELEVENLABS_API_KEY=
# Pick a voice from your ElevenLabs account (required if you use /api/tts)
ELEVENLABS_VOICE_ID=
# Optional: defaults to eleven_multilingual_v2
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# LiveKit (for voice sessions)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Google Maps (optional, for geocoding)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_key_here

# RentCast (live listings)
RENTCAST_API_KEY=

# Resend (transactional email — used by the Report tab "Email me a property summary" action)
# Get a key at https://resend.com — free tier supports onboarding@resend.dev as sender.
RESEND_API_KEY=
# From address for outbound emails (must be verified in Resend, or use onboarding@resend.dev for testing)
RESEND_FROM=Helio <onboarding@resend.dev>
