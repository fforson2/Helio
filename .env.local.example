# Mapbox GL JS (powers the 2D + 3D map on the Map tab)
# Create a PUBLIC token at https://account.mapbox.com/access-tokens/
# Public tokens start with `pk.` — secret tokens (`sk.`) WILL NOT work in the browser.
# 2D uses the dark style; 3D uses Mapbox Standard with real building extrusions.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Google Maps (Static Maps + Street View images for property cards)
# The Map tab no longer uses this — only the photo URLs in lib/server/listings.ts do.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ElevenLabs (Text-to-Speech)
ELEVENLABS_API_KEY=
# Pick a voice from your ElevenLabs account (required if you use /api/tts)
ELEVENLABS_VOICE_ID=
# Optional: defaults to eleven_multilingual_v2
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# LiveKit (future voice sessions)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Listings provider (future live inventory)
RENTCAST_API_KEY=

# Sketchfab archetype models for the Tour tab optional upgrade path.
# If left blank, Helio falls back to built-in public demo models.
# Add one UID or a comma-separated list of UIDs from Sketchfab viewer URLs
# to override the built-in pool for an archetype.
SKETCHFAB_MODEL_SINGLE_FAMILY=
SKETCHFAB_MODEL_RANCH=
SKETCHFAB_MODEL_TOWNHOUSE=
SKETCHFAB_MODEL_CONDO=
SKETCHFAB_MODEL_LUXURY=

# Resend (transactional email — used by the Report tab "Email me a property summary" action)
# Get a key at https://resend.com — free tier supports onboarding@resend.dev as sender.
RESEND_API_KEY=
# From address for outbound emails (must be verified in Resend, or use onboarding@resend.dev for testing)
RESEND_FROM=Helio <onboarding@resend.dev>
